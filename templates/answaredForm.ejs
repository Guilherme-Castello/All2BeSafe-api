<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      :root {
        --color-green:   #8bc34a;
        --color-red:     #e74c3c;
        --color-blue:    #2980b9;
        --color-teal:    #26a69a;
        --bg-section:    #2c3e50;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
        padding: 20px;
        color: #333;
        font-size: 13px;
      }

      /* ── Cabeçalho ── */
      .report-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 28px;
        padding-bottom: 16px;
        border-bottom: 2px solid #eee;
      }

      .logo {
        flex-shrink: 0;
        width: 110px;
      }

      .logo svg {
        width: 100%;
        height: auto;
        display: block;
      }

      .header-info {
        flex: 1;
      }

      .header-info h1 {
        font-size: 1.2em;
        margin-bottom: 6px;
        color: #2c3e50;
      }

      .form-meta {
        font-size: 0.85em;
        color: #666;
        line-height: 1.8;
      }

      /* ── Cabeçalho de seção ── */
      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--bg-section);
        color: #fff;
        padding: 8px 12px;
        margin-top: 18px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.92em;
        letter-spacing: 0.03em;
      }

      .section-percentage {
        font-weight: 400;
        font-size: 0.88em;
        opacity: 0.85;
      }

      /* ── Linha de questão ── */
      .question-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 10px 10px;
        border-bottom: 1px solid #eee;
        gap: 12px;
      }

      .question-title {
        flex: 1;
        font-weight: 500;
        word-break: break-word;
        padding-top: 2px;
      }

      /* Badge de resposta (YES / NO / N/A …) */
      .answer-badge {
        flex-shrink: 0;
        min-width: 60px;
        text-align: center;
        padding: 4px 14px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.85em;
        color: #fff;
        align-self: center;
      }

      /* Resposta longa sem badge (texto alinhado à direita) */
      .answer-text {
        flex-shrink: 0;
        max-width: 45%;
        text-align: right;
        color: #555;
        font-size: 0.85em;
        word-break: break-word;
        align-self: center;
      }

      .badge-green   { background-color: var(--color-green); }
      .badge-red     { background-color: var(--color-red);   }
      .badge-blue    { background-color: var(--color-blue);  }
      .badge-teal    { background-color: var(--color-teal);  }

      /* ── Check_boxes: lista de opções ── */
      .checkbox-list {
        flex-shrink: 0;
        max-width: 55%;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-self: center;
        text-align: right;
      }

      .checkbox-item {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        font-size: 0.85em;
        color: #555;
      }

      .checkbox-item.checked {
        color: #2e7d32;
        font-weight: 600;
      }

      .cb-mark {
        display: inline-block;
        width: 14px;
        height: 14px;
        border-radius: 3px;
        border: 1.5px solid #aaa;
        flex-shrink: 0;
        text-align: center;
        line-height: 12px;
        font-size: 10px;
      }

      .cb-mark.checked {
        background-color: var(--color-green);
        border-color: var(--color-green);
        color: #fff;
      }

      /* ── Extras (nota + fotos) abaixo da linha ── */
      .row-extras {
        padding: 6px 10px 14px 14px;
        border-bottom: 1px solid #eee;
      }

      .note-text {
        color: #666;
        font-style: italic;
        margin-bottom: 10px;
        font-size: 0.88em;
      }

      .photo-container {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 6px;
      }

      .photo-item img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ddd;
      }

      /* ── Assinatura ── */
      .signature-section {
        margin-top: 40px;
        border-top: 2px solid #eee;
        padding-top: 20px;
      }

      .signature-block {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
        padding: 10px 10px 14px;
        border-bottom: 1px solid #eee;
      }

      .signature-block .question-title {
        font-weight: 600;
        margin-bottom: 4px;
      }

      .signature-signer {
        font-size: 0.88em;
        color: #555;
      }

      .signature-img {
        max-width: 220px;
        max-height: 110px;
        border: 1px solid #ddd;
        border-radius: 4px;
        background: #fff;
      }
    </style>
  </head>

  <body>
    <div class="report-header">
      <% if (logoSvg) { %>
        <div class="logo"><%- logoSvg %></div>
      <% } %>
      <div class="header-info">
        <h1><%= form.config?.name || 'Relatório' %></h1>
        <div class="form-meta">
          <div><strong>Responsável:</strong> <%= form.config?.in_charge || '-' %></div>
          <div><strong>Descrição:</strong> <%= form.config?.description || '-' %></div>
          <div><strong>Respondido por:</strong> <%= answare?.name || '-' %></div>
        </div>
      </div>
    </div>

    <% if (form.questions && form.questions.length > 0) { %>

      <%
        // Agrupa questões por seção mantendo a ordem de primeira aparição.
        // Garante que cada seção apareça uma única vez mesmo que as questões
        // estejam intercaladas no array original.
        const sectionOrder = [];
        const sectionMap   = {};
        form.questions.forEach(function(q) {
          const sec = q.section || '__sem_secao__';
          if (!sectionMap[sec]) {
            sectionMap[sec] = [];
            sectionOrder.push(sec);
          }
          sectionMap[sec].push(q);
        });
      %>

      <% sectionOrder.forEach(function(sectionName) { %>
        <%
          const isRealSection = sectionName !== '__sem_secao__';
          const pctObj = isRealSection
            ? (answare.complete_percentage || []).find(function(p) { return p.section_name === sectionName; })
            : null;
          const pctStr = pctObj ? Math.round(pctObj.percentage) + '%' : '';
        %>

        <% if (isRealSection) { %>
          <div class="section-header">
            <span><%= sectionName %></span>
            <% if (pctStr) { %><span class="section-percentage"><%= pctStr %> completo</span><% } %>
          </div>
        <% } %>

        <% sectionMap[sectionName].forEach(function(q) { %>
          <% const ansObj = getAnswareObj(q.id); %>

          <% if (q.kind === 'check_boxes') { %>
            <%
              const boxes = (ansObj && Array.isArray(ansObj.answare_checkboxes) && ansObj.answare_checkboxes.length > 0)
                ? ansObj.answare_checkboxes
                : (Array.isArray(q.check_boxes) ? q.check_boxes.map(function(b) { return Object.assign({}, b, { value: false }); }) : []);
            %>
            <div class="question-row">
              <div class="question-title"><%= q.title %></div>
              <% if (boxes.length > 0) { %>
                <div class="checkbox-list">
                  <% boxes.forEach(function(box) { %>
                    <% const isChecked = !!box.value; %>
                    <div class="checkbox-item <%= isChecked ? 'checked' : '' %>">
                      <span><%= box.label %></span>
                      <span class="cb-mark <%= isChecked ? 'checked' : '' %>"><%= isChecked ? '✓' : '' %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

          <% } else if (q.kind === 'signature') { %>
            <div class="signature-block">
              <div class="question-title"><%= q.title %></div>
              <% if (ansObj && ansObj.answare_signer_name) { %>
                <div class="signature-signer"><strong>Nome:</strong> <%= ansObj.answare_signer_name %></div>
              <% } %>
              <% if (ansObj && ansObj.answare_text) { %>
                <img class="signature-img" src="<%= ansObj.answare_text %>" alt="Assinatura">
              <% } %>
            </div>

          <% } else { %>
            <%
              const ansText    = getAnswareText(ansObj, q.kind);
              const badgeClass = getBadgeClass(ansText);
              const isLongText = !badgeClass && !!ansText;
            %>
            <div class="question-row">
              <div class="question-title"><%= q.title %></div>

              <% if (badgeClass) { %>
                <div class="answer-badge <%= badgeClass %>"><%- ansText %></div>
              <% } else if (isLongText) { %>
                <div class="answer-text"><%- ansText %></div>
              <% } %>
            </div>
          <% } %>

          <% const hasNote   = ansObj && ansObj.answare_note && ansObj.answare_note.trim(); %>
          <% const hasImages = ansObj && Array.isArray(ansObj.answare_images) && ansObj.answare_images.length > 0; %>

          <% if (hasNote || hasImages) { %>
            <div class="row-extras">
              <% if (hasNote) { %>
                <div class="note-text"><%= ansObj.answare_note %></div>
              <% } %>
              <%- renderAnswareImages(ansObj) %>
            </div>
          <% } %>

        <% }) %>

      <% }) %>

    <% } else { %>
      <p style="text-align:center">Nenhuma pergunta encontrada.</p>
    <% } %>

  </body>

  <%
    function renderAnswareImages(a) {
      if (!a || !Array.isArray(a.answare_images) || a.answare_images.length === 0) return '';
      const imgs = a.answare_images
        .map((url, i) => `<div class="photo-item"><img src="${url}" alt="Foto ${i + 1}"></div>`)
        .join('');
      return `<div class="photo-container">${imgs}</div>`;
    }

    function getAnswareText(a, kind) {
      if (!a) return '';

      if (kind === 'signature' && a.answare_text) {
        return `<img src="${a.answare_text}" alt="Assinatura" style="max-width:200px;max-height:80px;">`;
      }

      if ((kind === 'input_time' || kind === 'input_date') && a.answare_text) {
        const d = new Date(a.answare_text);
        if (isNaN(d.getTime())) return a.answare_text || '';
        if (kind === 'input_time') {
          return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
        }
        return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
      }

      return a.answare_text || '';
    }

    function getAnswareObj(questionId) {
      if (!answare || !answare.answares) return null;
      return answare.answares.find(a => a.question_id?.toString() == questionId?.toString()) || null;
    }

    function getBadgeClass(text) {
      if (!text || typeof text !== 'string') return null;
      const t = text.trim().toUpperCase();
      if (['YES', 'SIM', 'OK', 'BOM', 'GOOD', 'SAFE', 'SEGURO'].includes(t)) return 'badge-green';
      if (['NO', 'NÃO', 'NAO', 'RUIM', 'BAD', 'PERIGOSO'].includes(t))       return 'badge-red';
      if (['N/A', 'NA', 'N/D'].includes(t))                                   return 'badge-blue';
      if (['PARTIAL', 'PARCIAL', 'MEDIUM', 'MÉDIO'].includes(t))              return 'badge-teal';
      return null;
    }
  %>
</html>
