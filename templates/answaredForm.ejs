<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --color-green:   #8bc34a;
        --color-red:     #e74c3c;
        --color-blue:    #2980b9;
        --color-teal:    #26a69a;
        --bg-section:    #2c3e50;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Roboto', Arial, sans-serif;
        padding: 20px;
        color: #333;
        font-size: 13px;
      }

      /* ── Cabeçalho ── */
      .logo {
        width: 130px;
        display: block;
        margin: 0 auto 12px;
      }

      h1 {
        text-align: center;
        font-size: 1.3em;
        margin-bottom: 4px;
      }

      .form-meta {
        text-align: center;
        font-size: 0.85em;
        color: #666;
        margin-bottom: 28px;
        line-height: 1.6;
      }

      /* ── Cabeçalho de seção ── */
      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--bg-section);
        color: #fff;
        padding: 8px 12px;
        margin-top: 18px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.92em;
        letter-spacing: 0.03em;
      }

      .section-percentage {
        font-weight: 400;
        font-size: 0.88em;
        opacity: 0.85;
      }

      /* ── Linha de questão ── */
      .question-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 10px;
        border-bottom: 1px solid #eee;
        gap: 12px;
      }

      .question-title {
        flex: 1;
        font-weight: 500;
        word-break: break-word;
      }

      /* Badge de resposta — aparece apenas para respostas curtas */
      .answer-badge {
        flex-shrink: 0;
        min-width: 60px;
        text-align: center;
        padding: 4px 14px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.85em;
        color: #fff;
      }

      /* Resposta longa sem badge (texto simples alinhado à direita) */
      .answer-text {
        flex-shrink: 0;
        max-width: 45%;
        text-align: right;
        color: #555;
        font-size: 0.85em;
        word-break: break-word;
      }

      .badge-green   { background-color: var(--color-green); }
      .badge-red     { background-color: var(--color-red);   }
      .badge-blue    { background-color: var(--color-blue);  }
      .badge-teal    { background-color: var(--color-teal);  }

      /* ── Extras (nota + fotos) abaixo da linha ── */
      .row-extras {
        padding: 6px 10px 14px 14px;
        border-bottom: 1px solid #eee;
      }

      .note-text {
        color: #666;
        font-style: italic;
        margin-bottom: 10px;
        font-size: 0.88em;
      }

      .photo-container {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 6px;
      }

      .photo-item img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ddd;
      }

      /* ── Assinatura ── */
      .signature-section {
        margin-top: 40px;
        border-top: 2px solid #eee;
        padding-top: 20px;
      }
    </style>
  </head>

  <body>
    <img
      class="logo"
      src="data:image/png;base64,"
    />

    <h1><%= form.config?.name || 'Relatório' %></h1>
    <div class="form-meta">
      <div><strong>Responsável:</strong> <%= form.config?.in_charge || '-' %></div>
      <div><strong>Descrição:</strong> <%= form.config?.description || '-' %></div>
      <div><strong>Respondido por:</strong> <%= answare?.name || '-' %></div>
    </div>

    <% if (form.questions && form.questions.length > 0) { %>

      <%
        let currentSection = null;

        form.questions.forEach((q) => {
          const ansObj    = getAnswareObj(q.id);
          const ansText   = getAnswareText(ansObj, q.kind);
          const badgeClass = getBadgeClass(ansText);
          const isLongText = !badgeClass && !!ansText;
          const sectionChanged = q.section && q.section !== currentSection;
          if (sectionChanged) { currentSection = q.section; }
      %>

        <% if (sectionChanged) { %>
          <%
            const pctObj = (answare.complete_percentage || []).find(p => p.section_name === currentSection);
            const pctStr = pctObj ? Math.round(pctObj.percentage) + '%' : '';
          %>
          <div class="section-header">
            <span><%= currentSection %></span>
            <% if (pctStr) { %><span class="section-percentage"><%= pctStr %> completo</span><% } %>
          </div>
        <% } %>

        <div class="question-row">
          <div class="question-title"><%= q.title %></div>

          <% if (badgeClass) { %>
            <div class="answer-badge <%= badgeClass %>"><%- ansText %></div>
          <% } else if (isLongText) { %>
            <div class="answer-text"><%- ansText %></div>
          <% } %>
        </div>

        <% const hasNote   = ansObj && ansObj.answare_note && ansObj.answare_note.trim(); %>
        <% const hasImages = ansObj && Array.isArray(ansObj.answare_images) && ansObj.answare_images.length > 0; %>

        <% if (hasNote || hasImages) { %>
          <div class="row-extras">
            <% if (hasNote) { %>
              <div class="note-text"><%= ansObj.answare_note %></div>
            <% } %>
            <%- renderAnswareImages(ansObj) %>
          </div>
        <% } %>

      <% }) %>

    <% } else { %>
      <p style="text-align:center">Nenhuma pergunta encontrada.</p>
    <% } %>

    <% if (answare?.signature) { %>
      <div class="signature-section">
        <p><strong>Assinatura:</strong></p>
        <img
          src="<%= answare.signature %>"
          alt="Assinatura"
          style="width:250px; border:1px dashed #ccc; padding:5px; margin-top:8px;"
        />
      </div>
    <% } %>

  </body>

  <%
    function renderAnswareImages(a) {
      if (!a || !Array.isArray(a.answare_images) || a.answare_images.length === 0) return '';
      const imgs = a.answare_images
        .map((url, i) => `<div class="photo-item"><img src="${url}" alt="Foto ${i + 1}"></div>`)
        .join('');
      return `<div class="photo-container">${imgs}</div>`;
    }

    function getAnswareText(a, kind) {
      if (a && Array.isArray(a.answare_checkboxes) && a.answare_checkboxes.length > 0) {
        const checked = a.answare_checkboxes.filter(b => b.value === true).map(b => b.label);
        return checked.length ? checked.join(', ') : '';
      }

      if (kind === 'signature' && a?.answare_text) {
        return `<img src="${a.answare_text}" alt="Assinatura" style="max-width:200px;max-height:80px;">`;
      }

      if ((kind === 'input_time' || kind === 'input_date') && a?.answare_text) {
        const d = new Date(a.answare_text);
        if (isNaN(d.getTime())) return '';
        if (kind === 'input_time') {
          return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });
        }
        return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
      }

      return a?.answare_text ?? '';
    }

    function getAnswareObj(questionId) {
      if (!answare || !answare.answares) return null;
      return answare.answares.find(a => a.question_id?.toString() == questionId?.toString());
    }

    function getBadgeClass(text) {
      if (!text || typeof text !== 'string') return null;
      const t = text.trim().toUpperCase();
      if (['YES', 'SIM', 'OK', 'BOM', 'GOOD', 'SAFE', 'SEGURO'].includes(t)) return 'badge-green';
      if (['NO', 'NÃO', 'NAO', 'RUIM', 'BAD', 'PERIGOSO'].includes(t))       return 'badge-red';
      if (['N/A', 'NA', 'N/D'].includes(t))                                   return 'badge-blue';
      if (['PARTIAL', 'PARCIAL', 'MEDIUM', 'MÉDIO'].includes(t))              return 'badge-teal';
      return null;
    }
  %>
</html>
